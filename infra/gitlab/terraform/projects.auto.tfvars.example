gitlab_token = "REPLACE_WITH_PLATFORM_PROVISIONER_PAT"

# Optional platform parent group. Leave null to create tenant groups at the GitLab root.
parent_group_id = null

tenants = {
  acme = {
    name        = "Acme Corp"
    path        = "acme"
    description = "Acme tenant namespace managed by divband"

    variables = {
      DIVBAND_TENANT_ID = {
        value     = "tenant-acme"
        protected = true
      }
    }

    projects = {
      marketing = {
        name                 = "Marketing Site"
        path                 = "marketing"
        kubernetes_namespace = "project-marketing"
        # Terraform creates the project-scoped runner and exports its
        # authentication token as runner_authentication_tokens["acme/marketing"].
        # Move that token to Vault, or let the Ansible runner role read the output
        # during the same protected provisioning run.
        runner_tag           = "divband-marketing"

        protected_branches = {
          production = {
            push_access_level  = "no one"
            merge_access_level = "maintainer"
          }
        }

        variables = {
          DIVBAND_ENVIRONMENT = {
            value     = "production"
            protected = true
          }
        }

        secrets = {
          # Preferred for the shared CI templates: base64 -w0 infra/ansible/artifacts/kubeconfig
          KUBE_CONFIG_B64 = {
            value     = "REPLACE_WITH_BASE64_KUBECONFIG"
            protected = true
            masked    = true
          }

          # Optional plain kubeconfig for jobs that expect GitLab's KUBE_CONFIG convention.
          KUBE_CONFIG = {
            value     = "REPLACE_WITH_RAW_KUBECONFIG"
            protected = true
            masked    = false
          }
        }
      }
    }
  }
}
