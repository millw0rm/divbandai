[Unit]
Description=Divband GHCR pull-deploy webhook
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/divband
EnvironmentFile=/etc/divband/deploy.env
ExecStart=/usr/bin/python3 /opt/divband/scripts/deploy_webhook.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
