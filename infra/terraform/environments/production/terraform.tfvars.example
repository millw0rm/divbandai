# Copy to terraform.tfvars and replace provider-specific values before apply.
platform_domain       = "divband.ir"
public_ingress_target = "REPLACE_WITH_INGRESS_LOAD_BALANCER"

# Platform-owned DNS records are managed through Cloudflare. This is separate
# from infra/terraform/modules/dns-domain, which remains the contract for
# customer-owned custom-domain verification records.
manage_platform_dns_records = true
cloudflare_zone_id          = "REPLACE_WITH_CLOUDFLARE_ZONE_ID"
# Prefer CLOUDFLARE_API_TOKEN or TF_VAR_cloudflare_api_token in production.
# The token needs Zone:DNS:Edit on the platform_domain zone.
cloudflare_api_token = "REPLACE_WITH_CLOUDFLARE_API_TOKEN"

# Use CNAME for load balancer hostnames. Set to A or AAAA when
# public_ingress_target is an IP address. Cloudflare flattens apex CNAMEs.
platform_dns_record_type = "CNAME"
cloudflare_dns_ttl       = 1
cloudflare_dns_proxied   = false

# First-class platform hostnames managed in the Cloudflare zone. Set any value
# to "" to skip it, for example when API is served from the dashboard hostname
# or GitLab is not self-hosted.
dashboard_hostname     = "app.divband.ir"
api_hostname           = "api.divband.ir"
gitlab_hostname        = "gitlab.divband.ir"
observability_hostnames = ["grafana.divband.ir"]
# Additional platform-owned service names can be appended here.
platform_hostnames = []

kubeconfig_path    = "~/.kube/config"
kubeconfig_context = "divband-production"
cluster_name       = "divband-production"
cluster_endpoint   = "https://REPLACE_WITH_KUBERNETES_API_SERVER"

# Keep false when another cluster automation system installs Helm charts and use
# `terraform output` as the shared-platform wiring contract.
apply_kubernetes_resources = true

# Prefer injecting these through TF_VAR_* or a secure Terraform Cloud variable set.
# create_dns_provider_secret = true
# dns_provider_api_token      = "REPLACE_WITH_DNS_PROVIDER_TOKEN"
# create_external_secrets_vault_token_secret = true
# external_secrets_vault_token               = "REPLACE_WITH_VAULT_TOKEN"
