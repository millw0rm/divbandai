---
apiVersion: v1
kind: Namespace
metadata:
  name: {{ divband_namespace }}
  labels:
    app.kubernetes.io/part-of: divband
---
apiVersion: v1
kind: Secret
metadata:
  name: divband-backend-env
  namespace: {{ divband_namespace }}
  labels:
    app.kubernetes.io/name: divband-backend
    app.kubernetes.io/part-of: divband
type: Opaque
stringData:
  DATABASE_URL: {{ divband_database_url | string | to_json }}
  OBJECT_STORAGE_ACCESS_KEY_ID: {{ divband_object_storage_access_key_id | string | to_json }}
  OBJECT_STORAGE_SECRET_ACCESS_KEY: {{ divband_object_storage_secret_access_key | string | to_json }}
  GITLAB_URL: {{ divband_gitlab_url | string | to_json }}
{% if divband_gitlab_token | trim | length > 0 %}
  GITLAB_TOKEN: {{ divband_gitlab_token | string | to_json }}
{% endif %}
{% if divband_gitlab_access_token | trim | length > 0 %}
  GITLAB_ACCESS_TOKEN: {{ divband_gitlab_access_token | string | to_json }}
{% endif %}
{% if divband_gitlab_namespace_id | string | trim | length > 0 %}
  GITLAB_NAMESPACE_ID: {{ divband_gitlab_namespace_id | string | to_json }}
{% endif %}
  DIVBAND_TOKEN_HASH_PEPPER: {{ divband_token_hash_pepper | string | to_json }}
{% if divband_dns_provider_token | string | trim | length > 0 %}
  DNS_PROVIDER_TOKEN: {{ divband_dns_provider_token | string | to_json }}
{% endif %}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: divband-backend
  namespace: {{ divband_namespace }}
  labels:
    app.kubernetes.io/name: divband-backend
    app.kubernetes.io/part-of: divband
spec:
  replicas: {{ divband_backend_replicas }}
  selector:
    matchLabels:
      app.kubernetes.io/name: divband-backend
  template:
    metadata:
      labels:
        app.kubernetes.io/name: divband-backend
    spec:
      containers:
        - name: backend
          image: {{ divband_backend_image }}
          ports:
            - containerPort: {{ divband_backend_port }}
          env:
            - name: API_BASE_URL
              value: {{ divband_api_base_url | string | to_json }}
            - name: PUBLIC_SITE_DOMAIN
              value: {{ divband_public_site_domain | string | to_json }}
            - name: UPLOAD_DOMAIN
              value: {{ divband_upload_domain | string | to_json }}
            - name: OBJECT_STORAGE_BUCKET
              value: {{ divband_object_storage_bucket | string | to_json }}
            - name: OBJECT_STORAGE_ENDPOINT
              value: {{ divband_object_storage_endpoint | string | to_json }}
            - name: OBJECT_STORAGE_REGION
              value: {{ divband_object_storage_region | string | to_json }}
            - name: OBJECT_STORAGE_PROVIDER
              value: {{ divband_object_storage_provider | string | to_json }}
            - name: OBJECT_STORAGE_FORCE_PATH_STYLE
              value: {{ divband_object_storage_force_path_style | string | to_json }}
            - name: DIVBAND_INFRASTRUCTURE_PROFILE
              value: {{ divband_infrastructure_profile | string | to_json }}
            - name: DNS_PROVIDER
              value: {{ divband_dns_provider | string | to_json }}
            - name: DNS_PROVIDER_ENDPOINT
              value: {{ divband_dns_provider_endpoint | string | to_json }}
            - name: DNS_PROVIDER_DEFAULT_TTL_SECONDS
              value: {{ divband_dns_provider_default_ttl_seconds | string | to_json }}
            - name: DNS_PROVIDER_PLATFORM_INGRESS_TARGET
              value: {{ divband_dns_provider_platform_ingress_target | string | to_json }}
            - name: DNS_PROVIDER_APEX_RECORD_TYPE
              value: {{ divband_dns_provider_apex_record_type | string | to_json }}
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: divband-backend-env
                  key: DATABASE_URL
            - name: OBJECT_STORAGE_ACCESS_KEY_ID
              valueFrom:
                secretKeyRef:
                  name: divband-backend-env
                  key: OBJECT_STORAGE_ACCESS_KEY_ID
            - name: OBJECT_STORAGE_SECRET_ACCESS_KEY
              valueFrom:
                secretKeyRef:
                  name: divband-backend-env
                  key: OBJECT_STORAGE_SECRET_ACCESS_KEY
            - name: GITLAB_URL
              valueFrom:
                secretKeyRef:
                  name: divband-backend-env
                  key: GITLAB_URL
{% if divband_gitlab_token | trim | length > 0 %}
            - name: GITLAB_TOKEN
              valueFrom:
                secretKeyRef:
                  name: divband-backend-env
                  key: GITLAB_TOKEN
{% endif %}
{% if divband_gitlab_access_token | trim | length > 0 %}
            - name: GITLAB_ACCESS_TOKEN
              valueFrom:
                secretKeyRef:
                  name: divband-backend-env
                  key: GITLAB_ACCESS_TOKEN
{% endif %}
{% if divband_gitlab_namespace_id | string | trim | length > 0 %}
            - name: GITLAB_NAMESPACE_ID
              valueFrom:
                secretKeyRef:
                  name: divband-backend-env
                  key: GITLAB_NAMESPACE_ID
{% endif %}
            - name: DIVBAND_TOKEN_HASH_PEPPER
              valueFrom:
                secretKeyRef:
                  name: divband-backend-env
                  key: DIVBAND_TOKEN_HASH_PEPPER
{% if divband_dns_provider_token | string | trim | length > 0 %}
            - name: DNS_PROVIDER_TOKEN
              valueFrom:
                secretKeyRef:
                  name: divband-backend-env
                  key: DNS_PROVIDER_TOKEN
{% endif %}
{% set reserved_env = [
  'API_BASE_URL',
  'PUBLIC_SITE_DOMAIN',
  'UPLOAD_DOMAIN',
  'OBJECT_STORAGE_BUCKET',
  'OBJECT_STORAGE_ENDPOINT',
  'OBJECT_STORAGE_REGION',
  'OBJECT_STORAGE_PROVIDER',
  'OBJECT_STORAGE_FORCE_PATH_STYLE',
  'DIVBAND_INFRASTRUCTURE_PROFILE',
  'OBJECT_STORAGE_ACCESS_KEY_ID',
  'OBJECT_STORAGE_SECRET_ACCESS_KEY',
  'DATABASE_URL',
  'DNS_PROVIDER',
  'DNS_PROVIDER_ENDPOINT',
  'DNS_PROVIDER_TOKEN',
  'DNS_PROVIDER_DEFAULT_TTL_SECONDS',
  'DNS_PROVIDER_PLATFORM_INGRESS_TARGET',
  'DNS_PROVIDER_APEX_RECORD_TYPE',
  'GITLAB_URL',
  'GITLAB_TOKEN',
  'GITLAB_ACCESS_TOKEN',
  'GITLAB_NAMESPACE_ID',
  'DIVBAND_TOKEN_HASH_PEPPER'
] %}
{% for key, value in divband_app_env.items() if key not in reserved_env %}
            - name: {{ key }}
              value: {{ value | string | to_json }}
{% endfor %}
          volumeMounts:
            - name: kubeconfig
              mountPath: {{ divband_kubeconfig_mount_path | dirname }}
              readOnly: true
      volumes:
        - name: kubeconfig
          secret:
            secretName: {{ divband_kubeconfig_secret_name }}
            items:
              - key: config
                path: config
---
apiVersion: v1
kind: Service
metadata:
  name: divband-backend
  namespace: {{ divband_namespace }}
spec:
  selector:
    app.kubernetes.io/name: divband-backend
  ports:
    - name: http
      port: 80
      targetPort: {{ divband_backend_port }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: divband-frontend
  namespace: {{ divband_namespace }}
  labels:
    app.kubernetes.io/name: divband-frontend
    app.kubernetes.io/part-of: divband
spec:
  replicas: {{ divband_frontend_replicas }}
  selector:
    matchLabels:
      app.kubernetes.io/name: divband-frontend
  template:
    metadata:
      labels:
        app.kubernetes.io/name: divband-frontend
    spec:
      containers:
        - name: frontend
          image: {{ divband_frontend_image }}
          ports:
            - containerPort: {{ divband_frontend_port }}
---
apiVersion: v1
kind: Service
metadata:
  name: divband-frontend
  namespace: {{ divband_namespace }}
spec:
  selector:
    app.kubernetes.io/name: divband-frontend
  ports:
    - name: http
      port: 80
      targetPort: {{ divband_frontend_port }}
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: divband-control-plane
  namespace: {{ divband_namespace }}
  annotations:
    cert-manager.io/cluster-issuer: {{ cert_manager_cluster_issuer | default('letsencrypt-prod') }}
spec:
  ingressClassName: {{ ingress_class_name | default('nginx') }}
  tls:
    - hosts:
        - {{ divband_public_hostname }}
      secretName: divband-control-plane-tls
  rules:
    - host: {{ divband_public_hostname }}
      http:
        paths:
          - path: /api
            pathType: Prefix
            backend:
              service:
                name: divband-backend
                port:
                  number: 80
          - path: /
            pathType: Prefix
            backend:
              service:
                name: divband-frontend
                port:
                  number: 80
