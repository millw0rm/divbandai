---
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: {{ cert_manager_cluster_issuer }}
  labels:
    app.kubernetes.io/managed-by: ansible
    app.kubernetes.io/part-of: divband
spec:
  acme:
    email: {{ cert_manager_acme_email }}
    server: {{ cert_manager_acme_server }}
    privateKeySecretRef:
      name: {{ cert_manager_private_key_secret_name }}
    solvers:
      - http01:
          ingress:
            class: {{ cert_manager_http01_ingress_class }}
---
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: {{ cert_manager_dns01_cluster_issuer }}
  labels:
    app.kubernetes.io/managed-by: ansible
    app.kubernetes.io/part-of: divband
spec:
  acme:
    email: {{ cert_manager_acme_email }}
    server: {{ cert_manager_acme_server }}
    privateKeySecretRef:
      name: {{ cert_manager_dns01_private_key_secret_name }}
    solvers:
      - selector:
          dnsZones:
{% for zone in cert_manager_dns01_zones %}
            - {{ zone }}
{% endfor %}
        dns01:
          webhook:
            groupName: {{ cert_manager_dns01_webhook_group_name }}
            solverName: {{ cert_manager_dns01_webhook_solver_name }}
            config:
              endpoint: {{ cert_manager_dns01_webhook_endpoint }}
              tokenSecretRef:
                name: {{ cert_manager_dns01_webhook_token_secret_name }}
                key: {{ cert_manager_dns01_webhook_token_secret_key }}
