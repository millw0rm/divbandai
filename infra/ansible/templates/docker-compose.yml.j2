services:
  haproxy:
    image: "{{ 'docker.arvancloud.ir/' if divband_arvan_enabled | bool else '' }}haproxy:2.9-alpine"
    container_name: divband-haproxy
    restart: unless-stopped
    ports:
      - "80:80"
    volumes:
      - ./config/haproxy/haproxy.cfg:/usr/local/etc/haproxy/haproxy.cfg:ro
    depends_on:
{% for project in divband_projects %}
      - {{ project.name }}-web
{% endfor %}
    networks:
      - divband

{% for project in divband_projects %}
  {{ project.name }}-web:
{% if project.kind | default('static') == 'nextjs' %}
    image: divband-{{ project.name }}:local
    build:
      context: ./projects/{{ project.name }}
      dockerfile: Dockerfile
    container_name: divband-{{ project.name }}-web
    restart: unless-stopped
    environment:
      NODE_ENV: production
    networks:
      - divband
{% else %}
    image: "{{ 'docker.arvancloud.ir/' if divband_arvan_enabled | bool else '' }}nginx:1.27-alpine"
    container_name: divband-{{ project.name }}-web
    restart: unless-stopped
    volumes:
      - ./projects/{{ project.name }}/html:/usr/share/nginx/html:ro
      - ./projects/{{ project.name }}/nginx.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - divband
{% endif %}
{% endfor %}

networks:
  divband:
    name: divband
