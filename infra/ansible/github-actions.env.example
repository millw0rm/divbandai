# Copy to a local, untracked file if desired, edit values, then source it before
# running `make configure-github-actions`.
#
# Example:
#   cp infra/ansible/github-actions.env.example .secrets/github-actions.env
#   . .secrets/github-actions.env
#   make configure-github-actions

GITHUB_REPOSITORY=millw0rm/divband
DIVBAND_KEYRING_PASSWORD_FILE=.secrets/keyring-password

DIVBAND_VPS_HOST=185.204.170.33
DIVBAND_VPS_USER=ubuntu
DIVBAND_SOURCE_REPO_URL=https://github.com/millw0rm/divband.git

# Control-plane hostname rendered into the divband-system Ingress.
DIVBAND_PUBLIC_HOSTNAME=divband.com

# Backend API URL compiled into the frontend image and used by clients/CI.
DIVBAND_API_BASE_URL=https://divband.com/api

# Platform domain used for project hostnames:
#   {projectSlug}.{username}.${DIVBAND_PUBLIC_SITE_DOMAIN}
DIVBAND_PUBLIC_SITE_DOMAIN=divband.com

DIVBAND_UPLOAD_DOMAIN=uploads.divband.com

# ACME account used by cert-manager ClusterIssuers. Do not use example.com;
# Let's Encrypt rejects that domain for account contacts.
CERT_MANAGER_ACME_EMAIL=admin@divband.com
CERT_MANAGER_CLUSTER_ISSUER=letsencrypt-staging
CERT_MANAGER_ACME_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory

CLUSTER_REGISTRY_ENDPOINT=localhost:30500
