{
  "schema_version": "2026-05-29",
  "name": "divband Agent Publishing",
  "description": "Agent-first static-site publishing for prebuilt HTML, CSS, JavaScript, and assets.",
  "service_url": "https://divband.local",
  "api_base_url": "https://api.divband.local",
  "openapi_url": "https://divband.local/openapi.json",
  "llms_txt_url": "https://divband.local/llms.txt",
  "pricing_url": "https://divband.local/pricing.md",
  "documentation_url": "https://divband.local/docs/agent-distribution",
  "mcp": {
    "package": "@divband/mcp-server",
    "command": "npx",
    "args": ["@divband/mcp-server"],
    "env": ["DIVBAND_API_BASE_URL", "DIVBAND_API_TOKEN"]
  },
  "auth": {
    "modes": ["anonymous_claim_token", "bearer_api_token"],
    "bearer_header": "Authorization: Bearer ${DIVBAND_API_TOKEN}",
    "credential_storage": "Store DIVBAND_API_TOKEN in the agent's local secret manager or encrypted environment store. Never commit claim tokens or API tokens."
  },
  "capabilities": [
    "publish_static_site",
    "update_static_site",
    "claim_anonymous_site",
    "list_owned_sites",
    "delete_site"
  ],
  "limits": {
    "anonymous_retention_hours": 24,
    "upload_url_ttl_seconds": 900,
    "max_anonymous_ttl_seconds": 2592000
  },
  "contact": {
    "support": "support@divband.local",
    "security": "security@divband.local"
  }
}
