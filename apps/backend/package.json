{
  "name": "@divband/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Platform API for project lifecycle orchestration.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "node --experimental-transform-types src/server.ts",
    "build": "tsc --noEmit --project ../../tsconfig.json",
    "start": "node --experimental-transform-types src/server.ts",
    "smoke:controls": "node --experimental-transform-types scripts/production-controls-smoke.mjs",
    "smoke:restore": "node --experimental-transform-types scripts/restore-smoke.mjs",
    "smoke:publish": "node --experimental-transform-types scripts/publish-smoke.mjs"
  },
  "dependencies": {
    "pg": "^8.13.1"
  }
}
